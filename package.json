{
  "name": "ecen-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "powershell -ExecutionPolicy Bypass -File clean.ps1",
    "dev": "next dev --port 3001",
    "dev:stable": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "prepare": "husky install"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "framer-motion": "^12.23.25",
    "lucide-react": "^0.555.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "postcss": "^8",
    "prettier": "^3.1.1",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
